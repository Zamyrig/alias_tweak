#!/usr/bin/env bash
# mkalias — alias manager with Fish shell support
# Usage: mkalias [name=value] [-a] [-r name] [-l]

set -euo pipefail

# ─── Config paths ────────────────────────────────────────────────────────────
GLOBAL_ALIAS_DIR="/etc/mkalias"
GLOBAL_ALIAS_FILE="$GLOBAL_ALIAS_DIR/aliases.conf"
USER_ALIAS_DIR="$HOME/.config/mkalias"
USER_ALIAS_FILE="$USER_ALIAS_DIR/aliases.conf"

FISH_GLOBAL_FUNC_DIR="/etc/fish/functions"
FISH_USER_FUNC_DIR="$HOME/.config/fish/functions"

# ─── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ─── Helpers ─────────────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}::${RESET} $*"; }
success() { echo -e "${GREEN}✔${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET}  $*"; }
error()   { echo -e "${RED}✖${RESET}  $*" >&2; exit 1; }

ensure_dirs() {
    mkdir -p "$USER_ALIAS_DIR"
    touch "$USER_ALIAS_FILE"
    mkdir -p "$FISH_USER_FUNC_DIR"
}

# ─── Fish function writers ────────────────────────────────────────────────────
write_fish_function() {
    local name="$1"
    local value="$2"
    local func_dir="$3"

    mkdir -p "$func_dir"
    cat > "$func_dir/${name}.fish" <<EOF
function $name
    $value \$argv
end
EOF
}

remove_fish_function() {
    local name="$1"
    local func_dir="$2"
    local f="$func_dir/${name}.fish"
    [[ -f "$f" ]] && rm -f "$f"
}

# ─── Add alias ───────────────────────────────────────────────────────────────
cmd_add() {
    local pair="$1"
    local global="${2:-false}"

    # Validate format
    if [[ ! "$pair" =~ ^[a-zA-Z0-9_-]+= ]]; then
        error "Invalid format. Use: mkalias name=value  (e.g. mkalias dc=docker-compose)"
    fi

    local name="${pair%%=*}"
    local value="${pair#*=}"

    if [[ -z "$name" || -z "$value" ]]; then
        error "Both alias name and value must be non-empty."
    fi

    if [[ "$global" == "true" ]]; then
        if [[ $EUID -ne 0 ]]; then
            error "Root privileges required to add a global alias. Use sudo."
        fi
        mkdir -p "$GLOBAL_ALIAS_DIR"
        touch "$GLOBAL_ALIAS_FILE"

        # Remove old entry if exists
        sed -i "/^${name}=/d" "$GLOBAL_ALIAS_FILE" 2>/dev/null || true
        echo "${name}=${value}" >> "$GLOBAL_ALIAS_FILE"

        write_fish_function "$name" "$value" "$FISH_GLOBAL_FUNC_DIR"
        success "Global alias added: ${BOLD}${name}${RESET} = ${value}"
    else
        ensure_dirs

        sed -i "/^${name}=/d" "$USER_ALIAS_FILE" 2>/dev/null || true
        echo "${name}=${value}" >> "$USER_ALIAS_FILE"

        write_fish_function "$name" "$value" "$FISH_USER_FUNC_DIR"
        success "User alias added: ${BOLD}${name}${RESET} = ${value}"
    fi
}

# ─── Remove alias ─────────────────────────────────────────────────────────────
cmd_remove() {
    local name="$1"
    local removed=false

    # Try user alias
    if [[ -f "$USER_ALIAS_FILE" ]] && grep -q "^${name}=" "$USER_ALIAS_FILE"; then
        sed -i "/^${name}=/d" "$USER_ALIAS_FILE"
        remove_fish_function "$name" "$FISH_USER_FUNC_DIR"
        success "Removed user alias: ${BOLD}${name}${RESET}"
        removed=true
    fi

    # Try global alias
    if [[ -f "$GLOBAL_ALIAS_FILE" ]] && grep -q "^${name}=" "$GLOBAL_ALIAS_FILE"; then
        if [[ $EUID -ne 0 ]]; then
            warn "Global alias '${name}' exists but requires sudo to remove."
        else
            sed -i "/^${name}=/d" "$GLOBAL_ALIAS_FILE"
            remove_fish_function "$name" "$FISH_GLOBAL_FUNC_DIR"
            success "Removed global alias: ${BOLD}${name}${RESET}"
            removed=true
        fi
    fi

    if [[ "$removed" == "false" ]]; then
        warn "Alias '${name}' not found."
    fi
}

# ─── List aliases ─────────────────────────────────────────────────────────────
cmd_list() {
    local show_all="${1:-false}"

    echo ""
    echo -e "${BOLD}  mkalias — alias list${RESET}"
    echo -e "${DIM}  ─────────────────────────────────────${RESET}"

    # Global aliases
    echo ""
    echo -e "  ${BOLD}[all users]${RESET}"
    if [[ -f "$GLOBAL_ALIAS_FILE" ]] && [[ -s "$GLOBAL_ALIAS_FILE" ]]; then
        while IFS='=' read -r aname avalue; do
            [[ -z "$aname" || "$aname" == \#* ]] && continue
            printf "  ${GREEN}%-18s${RESET}= %s\n" "$aname" "$avalue"
        done < "$GLOBAL_ALIAS_FILE"
    else
        echo -e "  ${DIM}alias list is empty${RESET}"
    fi

    # User aliases
    echo ""
    echo -e "  ${BOLD}[$(whoami)]${RESET}"
    if [[ -f "$USER_ALIAS_FILE" ]] && [[ -s "$USER_ALIAS_FILE" ]]; then
        while IFS='=' read -r aname avalue; do
            [[ -z "$aname" || "$aname" == \#* ]] && continue
            printf "  ${CYAN}%-18s${RESET}= %s\n" "$aname" "$avalue"
        done < "$USER_ALIAS_FILE"
    else
        echo -e "  ${DIM}alias list is empty${RESET}"
    fi

    # All users (if -a flag)
    if [[ "$show_all" == "true" ]]; then
        echo ""
        echo -e "  ${BOLD}[other users]${RESET}"
        local found_other=false
        if [[ -d "/home" ]]; then
            for udir in /home/*/; do
                local uname
                uname=$(basename "$udir")
                [[ "$uname" == "$(whoami)" ]] && continue
                local ufile="$udir/.config/mkalias/aliases.conf"
                if [[ -f "$ufile" ]] && [[ -s "$ufile" ]]; then
                    echo ""
                    echo -e "  ${BOLD}  [${uname}]${RESET}"
                    while IFS='=' read -r aname avalue; do
                        [[ -z "$aname" || "$aname" == \#* ]] && continue
                        printf "  ${YELLOW}  %-16s${RESET}= %s\n" "$aname" "$avalue"
                        found_other=true
                    done < "$ufile"
                else
                    echo -e "  ${DIM}  [${uname}] — alias list is empty${RESET}"
                    found_other=true
                fi
            done
        fi
        if [[ "$found_other" == "false" ]]; then
            echo -e "  ${DIM}  no other users found${RESET}"
        fi
    fi

    echo ""
}

# ─── Usage ───────────────────────────────────────────────────────────────────
usage() {
    echo ""
    echo -e "${BOLD}mkalias${RESET} — fish-first alias manager"
    echo ""
    echo -e "${BOLD}USAGE${RESET}"
    echo "  mkalias                    show aliases for current user + global"
    echo "  mkalias name=value         add user alias"
    echo "  mkalias -g name=value      add global alias (requires sudo)"
    echo "  mkalias -r name            remove alias"
    echo "  mkalias -l                 list aliases (same as bare mkalias)"
    echo "  mkalias -a                 list aliases including all users"
    echo ""
    echo -e "${BOLD}EXAMPLES${RESET}"
    echo "  mkalias dc=docker-compose"
    echo "  mkalias r=ranger"
    echo "  sudo mkalias -g m=micro"
    echo "  mkalias -r dc"
    echo "  mkalias -a"
    echo ""
}

# ─── Apply aliases to current bash/zsh session (sourcing) ───────────────────
cmd_source_bash() {
    # Outputs eval-able lines for bash/zsh
    if [[ -f "$GLOBAL_ALIAS_FILE" ]]; then
        while IFS='=' read -r aname avalue; do
            [[ -z "$aname" || "$aname" == \#* ]] && continue
            echo "alias ${aname}='${avalue}'"
        done < "$GLOBAL_ALIAS_FILE"
    fi
    if [[ -f "$USER_ALIAS_FILE" ]]; then
        while IFS='=' read -r aname avalue; do
            [[ -z "$aname" || "$aname" == \#* ]] && continue
            echo "alias ${aname}='${avalue}'"
        done < "$USER_ALIAS_FILE"
    fi
}

# ─── Entry point ─────────────────────────────────────────────────────────────
main() {
    ensure_dirs

    # No args → list
    if [[ $# -eq 0 ]]; then
        cmd_list false
        return
    fi

    # Parse
    local FLAG_ALL=false
    local FLAG_REMOVE=""
    local FLAG_LIST=false
    local FLAG_GLOBAL=false
    local FLAG_SOURCE=false
    local POSITIONAL=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -a|--all)    FLAG_ALL=true;          shift ;;
            -l|--list)   FLAG_LIST=true;          shift ;;
            -g|--global) FLAG_GLOBAL=true;        shift ;;
            --source-bash) FLAG_SOURCE=true;      shift ;;
            -r|--remove)
                if [[ -z "${2:-}" ]]; then
                    error "-r requires an alias name. E.g.: mkalias -r dc"
                fi
                FLAG_REMOVE="$2"; shift 2 ;;
            -h|--help)   usage; exit 0 ;;
            -*)          error "Unknown flag: $1. Use -h for help." ;;
            *)           POSITIONAL+=("$1"); shift ;;
        esac
    done

    # Handle flags
    if [[ "$FLAG_SOURCE" == "true" ]]; then
        cmd_source_bash
        return
    fi

    if [[ -n "$FLAG_REMOVE" ]]; then
        cmd_remove "$FLAG_REMOVE"
        return
    fi

    if [[ "$FLAG_ALL" == "true" || "$FLAG_LIST" == "true" ]]; then
        cmd_list "$FLAG_ALL"
        return
    fi

    # Positional = add alias
    if [[ ${#POSITIONAL[@]} -gt 0 ]]; then
        cmd_add "${POSITIONAL[0]}" "$FLAG_GLOBAL"
        return
    fi

    cmd_list false
}

main "$@"
